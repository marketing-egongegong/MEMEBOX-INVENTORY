# ── Required for live Amazon data ───────────────────────────────────────────
# Amazon source spreadsheet ID (the long token in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS>/edit )
GOOGLE_SHEET_ID=1EIA6i6rvD2ASB38tPbT2VQBSzfieuzNk-MeYkivJjB4

# Google service account key — raw JSON on one line OR base64-encoded JSON.
#   1) GCP Console → IAM → Service Accounts → create JSON key
#   2) Enable "Google Sheets API"
#   3) SHARE the spreadsheet with the service account email (Viewer) — required
# Base64 (recommended for Railway):  base64 -w0 key.json   (mac: base64 -i key.json | tr -d '\n')
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Optional ────────────────────────────────────────────────────────────────
# Railway injects PORT automatically; this is only for local runs.
PORT=8080
